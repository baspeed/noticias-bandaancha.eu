    inherited DzHTMLText12: TDzHTMLText
      Align = Client
      StyledSettings = [Family, Style, FontColor]
      Size.Width = 450.000000000000000000
      Size.Height = 551.000000000000000000
      Size.PlatformDefault = False
      Color = claWhite
      Lines.Strings = (
        
          'Para poder utilizar esta aplicaci'#243'n, debes saber que <b>tienes q' +
          'ue aceptar todas las normas de utilizaci'#243'n de los foros y los ar' +
          't'#237'culos</b> que se aplican al portal <b>bandaancha.eu</b>.'
        ''
        
          'El enlace a las normas de utilizaci'#243'n de los foros y los art'#237'cul' +
          'os de <b>bandaancha.eu</b> es el siguiente (se abrir'#225' el navegad' +
          'or de internet del dispositivo mostrando la p'#225'gina con las norma' +
          's): <a:https://wiki.bandaancha.st/Normas_de_los_foros>https://wi' +
          'ki.bandaancha.st/Normas_de_los_foros</a>'
        ''
        
          'Si deseas poder seguir utilizando esta aplicaci'#243'n y el portal <b' +
          '>bandaancha.eu</b>, cumpliendo las normas de utilizaci'#243'n de los ' +
          'foros y los art'#237'culos, entonces pulsa el bot'#243'n <b>Aceptar normas' +
          '</b> en la parte inferior. Este aviso se cerrar'#225' y no volver'#225' a ' +
          'mostrarse ya que la aceptaci'#243'n de las normas se realiza una '#250'nic' +
          'a vez al instalar y ejecutar la aplicaci'#243'n por primera vez en el' +
          ' dispositivo.'
        ''
        
          'Si no desea seguir usando esta aplicaci'#243'n, ya que puede que no e' +
          'st'#233' de acuerdo con las normas de utilizaci'#243'n de los foros y los ' +
          'art'#237'culos en <b>bandaancha.eu</b>, pulse el bot'#243'n Cancelar y sal' +
          'ir para cerrar la aplicaci'#243'n y volver a Android. En la siguiente' +
          ' ejecuci'#243'n de la aplicaci'#243'n te volver'#225' a aparecer este mensaje y' +
          'a que no aceptaste en su momento las normas de <b>bandaancha.eu<' +
          '/b>.')
      Borders.All = 5.000000000000000000
    end
  end
